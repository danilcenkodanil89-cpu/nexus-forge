{
  "name": "nexus-forge",
  "version": "1.0.1",
  "description": "Игровой лаунчер в стиле Wuthering Waves",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "generate-icon": "node assets/generate-icon.js",
    "generate-icon-nsis": "node assets/generate-icon-bmp.js"
  },
  "author": "HiSphere",
  "license": "MIT",
  "dependencies": {
    "extract-file-icon": "^0.3.2"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "ru.hisphere.nexusforge",
    "productName": "Nexus Forge",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "assets/**/*",
      "updater/**/*",
      "version.json"
    ],
    "win": {
      "icon": "assets/nexus-forge.ico",
      "target": "portable"
    },
    "publish": {
      "provider": "github",
      "owner": "danilcenkodanil89-cpu",
      "repo": "Nexus-Forge",
      "releaseType": "release"
    }
  }
}